{
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "author": "hackycy <hackycy@outlook.com>",
  "license": "MIT",
  "homepage": "https://github.com/hackycy/kit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hackycy/kit.git"
  },
  "bugs": "https://github.com/hackycy/kit/issues",
  "keywords": [],
  "sideEffects": false,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --filter='./packages/*'",
    "play": "pnpm -F ./playground dev",
    "test": "vitest run --dom",
    "lint": "eslint --cache .",
    "prepublishOnly": "pnpm build",
    "release": "bumpp -r",
    "typecheck": "tsc",
    "prepare": "simple-git-hooks",
    "open:packages": "npx open-packages-on-npm",
    "catalog": "pnpx codemod pnpm/catalog",
    "postinstall": "pnpm -r run build"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:cli",
    "@tsdown/css": "catalog:cli",
    "@types/node": "catalog:types",
    "bumpp": "catalog:cli",
    "eslint": "catalog:cli",
    "happy-dom": "catalog:testing",
    "lint-staged": "catalog:cli",
    "publint": "catalog:cli",
    "sass-embedded": "catalog:cli",
    "simple-git-hooks": "catalog:cli",
    "tsdown": "catalog:cli",
    "tsx": "catalog:cli",
    "turbo": "catalog:cli",
    "typescript": "catalog:cli",
    "unplugin-vue": "catalog:cli",
    "vite": "catalog:cli",
    "vitest": "catalog:testing",
    "vitest-package-exports": "catalog:testing"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm i --frozen-lockfile --ignore-scripts --offline && npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
