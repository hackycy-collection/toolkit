{
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.0",
  "author": "hackycy <hackycy@outlook.com>",
  "license": "MIT",
  "homepage": "https://github.com/hackycy-collection/toolkit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hackycy-collection/toolkit.git"
  },
  "bugs": "https://github.com/hackycy-collection/toolkit/issues",
  "keywords": [],
  "sideEffects": false,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "eslint --cache .",
    "prepublishOnly": "nr build",
    "release": "bumpp -r",
    "typecheck": "tsc",
    "prepare": "simple-git-hooks",
    "open:packages": "npx open-packages-on-npm",
    "catalog": "pnpx codemod pnpm/catalog"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:cli",
    "@tsdown/css": "catalog:cli",
    "@types/node": "catalog:types",
    "bumpp": "catalog:cli",
    "eslint": "catalog:cli",
    "lint-staged": "catalog:cli",
    "publint": "catalog:cli",
    "sass-embedded": "catalog:cli",
    "simple-git-hooks": "catalog:cli",
    "tsdown": "catalog:cli",
    "tsx": "catalog:cli",
    "turbo": "catalog:cli",
    "typescript": "catalog:cli",
    "vite": "catalog:cli",
    "vitest": "catalog:testing",
    "vitest-package-exports": "catalog:testing"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm i --frozen-lockfile --ignore-scripts --offline && npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
